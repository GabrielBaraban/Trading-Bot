# ── RPC endpoints (get a free key at https://alchemy.com or https://infura.io) ──
BASE_RPC_WSS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_HTTPS=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Your wallet (used for paper trading identity — no funds needed in paper mode) ──
MY_WALLET_ADDRESS=0xYourWalletAddress
MY_PRIVATE_KEY=your_private_key_here

# ── Wallets to copy (comma-separated) ──
WATCHED_WALLETS=0xWallet1,0xWallet2,0xWallet3

# ── Copy sizing ──
COPY_RATIO=0.01        # Copy 1% of their trade size
MAX_TRADE_USD=100      # Never copy more than $100 per trade
MIN_TRADE_USD=5        # Ignore trades below $5

# ── Execution ──
SLIPPAGE_BPS=50        # 0.5% slippage tolerance (for live mode)
PAPER_TRADING=true     # Set to false ONLY when ready for live trading

# ── Bot behaviour ──
MONITOR_INTERVAL=60    # Seconds between open-position re-price checks
MAX_HOLD_HOURS=24      # Auto-close positions older than this
